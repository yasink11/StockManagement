@model Category
@{
    ViewData["Title"] = "Kategori Düzenle";
}

<h2>Kategori Düzenle</h2>
<form asp-action="Edit" method="post" class="col-md-6">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Kategori Adı</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Güncelle</button>
    <a asp-action="Index" class="btn btn-secondary">İptal</a>
</form>
<form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-2" onsubmit="return confirm('Silmek istediğinize emin misiniz?');">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Sil</button>
</form>
