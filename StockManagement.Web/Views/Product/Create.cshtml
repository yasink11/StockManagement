@model Product
@{
    ViewData["Title"] = "Yeni Ürün";
}

<h2>Yeni Ürün</h2>
<form asp-action="Create" method="post" class="col-md-6">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">Kategori</label>
        <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-select">
            <option value="">-- Seçiniz --</option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Ürün Adı</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ImageSrc" class="form-label">Resim Yolu (IMAGE_SRC)</label>
        <input asp-for="ImageSrc" class="form-control" placeholder="/images/urun.jpg" />
    </div>
    <div class="mb-3">
        <label asp-for="Salesprice" class="form-label">Satış Fiyatı (SALESPRICE)</label>
        <input asp-for="Salesprice" class="form-control" type="number" step="0.01" />
    </div>
    <button type="submit" class="btn btn-primary">Kaydet</button>
    <a asp-action="Index" class="btn btn-secondary">İptal</a>
</form>
