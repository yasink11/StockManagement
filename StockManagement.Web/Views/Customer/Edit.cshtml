@model Customer
@{
    ViewData["Title"] = "Müşteri Düzenle";
}

<h2>Müşteri Düzenle</h2>
<form asp-action="Edit" method="post" class="col-md-6">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Customertitle" class="form-label">Müşteri Ünvanı</label>
        <input asp-for="Customertitle" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Customernumber" class="form-label">Müşteri Numarası</label>
        <input asp-for="Customernumber" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Güncelle</button>
    <a asp-action="Index" class="btn btn-secondary">İptal</a>
</form>
<form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-2" onsubmit="return confirm('Silmek istediğinize emin misiniz?');">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Sil</button>
</form>
