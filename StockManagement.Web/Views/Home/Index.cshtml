@{
    ViewData["Title"] = "Ana Sayfa";
    var dbOk = ViewBag.DbOk as bool? ?? false;
    var dbMessage = ViewBag.DbMessage as string;
}

@if (!dbOk)
{
    <div class="alert alert-danger alert-db mb-4">
        <strong><i class="bi bi-database-x me-1"></i>Veritabanı bağlantısı yok</strong><br />
        @dbMessage
        <div class="mt-2 small">
            SSMS'te sırayla: <code>db.sql</code> → <code>sql/create-sql-login.sql</code>
        </div>
    </div>
}

<div class="page-header mb-4">
    <div>
        <h1 class="h3 mb-1">Stok ve Satış Yönetimi</h1>
        <p class="text-muted mb-0">Ürün, alış, satış ve raporlama modülleri</p>
    </div>
</div>

<div class="row g-4 mb-4">

    <div class="col-md-6 col-lg-3">
        <a asp-controller="Product" asp-action="Index" class="text-decoration-none">
            <div class="card dashboard-card">
                <div class="card-body">
                    <div class="dashboard-icon bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-basket"></i>
                    </div>
                    <h5 class="card-title">Ürünler</h5>
                    <p class="card-text text-muted small mb-0">Ürün girişi ve güncelleme</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-3">
        <a asp-controller="Purchase" asp-action="Create" class="text-decoration-none">
            <div class="card dashboard-card">
                <div class="card-body">
                    <div class="dashboard-icon bg-success bg-opacity-10 text-success">
                        <i class="bi bi-cart-plus"></i>
                    </div>
                    <h5 class="card-title">Yeni Alış</h5>
                    <p class="card-text text-muted small mb-0">Purchase + Stock kaydı</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-3">
        <a asp-controller="Sales" asp-action="Create" class="text-decoration-none">
            <div class="card dashboard-card">
                <div class="card-body">
                    <div class="dashboard-icon bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-receipt"></i>
                    </div>
                    <h5 class="card-title">Yeni Satış</h5>
                    <p class="card-text text-muted small mb-0">İskonto ve stok kontrolü</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-6 col-lg-3">
        <a asp-controller="Report" asp-action="SalesDetail" class="text-decoration-none">
            <div class="card dashboard-card">
                <div class="card-body">
                    <div class="dashboard-icon bg-info bg-opacity-10 text-info">
                        <i class="bi bi-bar-chart"></i>
                    </div>
                    <h5 class="card-title">Satış Raporu</h5>
                    <p class="card-text text-muted small mb-0">Kategori bazlı analiz</p>
                </div>
            </div>
        </a>
    </div>

</div>


<div class="container-fluid px-0">

    <div class="mb-3">
        <h4 class="fw-bold">Dashboard</h4>
        <p class="text-muted small mb-0">Canlı satış ve stok analizi</p>
    </div>

    <div class="row g-4">

        <!-- SALES -->
        <div class="col-md-8">
            <div class="card shadow-sm rounded-4 p-3">
                <h6 class="mb-3">Aylık Satış</h6>
                <canvas id="salesChart"></canvas>
            </div>
        </div>

        <!-- SIDE -->
        <div class="col-md-4">

            <div class="card shadow-sm rounded-4 p-3 mb-3">
                <h6 class="mb-3">Aylık Alış</h6>
                <canvas id="purchaseChart"></canvas>
            </div>

            <div class="card shadow-sm rounded-4 p-3">
                <h6 class="mb-3">Kâr Durumu</h6>
                <canvas id="profitChart"></canvas>
            </div>

        </div>

    </div>

</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/home.js"></script>
}