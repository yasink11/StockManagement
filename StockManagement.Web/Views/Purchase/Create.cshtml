@model PurchaseCreateViewModel

@{
    ViewData["Title"] = "Yeni Alış";
}

<div class="d-flex justify-content-center align-items-center py-5" style="min-height: 80vh;">

    <div class="w-100" style="max-width: 900px;">

        <!-- HEADER -->
        <div class="text-center mb-4">
            <h2 class="fw-bold mb-1">Yeni Alış</h2>
            <p class="text-muted mb-0">Stok giriş işlemini oluştur</p>
        </div>

        <!-- CARD -->
        <div class="card border-0 shadow-lg rounded-4">
            <div class="card-body p-5">

                <form asp-action="Create" method="post" id="purchaseForm">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- TOP -->
                    <div class="row g-4">

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Müşteri</label>
                            <select asp-for="CustomerId"
                                    asp-items="ViewBag.CustomerId"
                                    class="form-select form-select-lg rounded-3">
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ürün</label>
                            <select asp-for="ProductId"
                                    asp-items="ViewBag.ProductId"
                                    class="form-select form-select-lg rounded-3"
                                    id="productSelect">
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Miktar</label>
                            <input asp-for="Quantity"
                                   class="form-control form-control-lg rounded-3"
                                   type="number"
                                   step="0.01"
                                   id="quantity" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Birim Fiyat</label>
                            <input asp-for="Price"
                                   class="form-control form-control-lg rounded-3"
                                   type="number"
                                   step="0.01"
                                   id="price" />
                        </div>

                    </div>

                    <!-- TOTAL (SALES İLE AYNI MAVİ GRADIENT) -->
                    <div class="mt-4 p-4 rounded-4 text-white d-flex justify-content-between align-items-center"
                         style="background: linear-gradient(135deg, #1e3c72, #2a5298);">

                        <div>
                            <div class="text-white-50 small">Toplam Tutar</div>
                            <div class="fs-3 fw-bold">
                                <input asp-for="Amount"
                                       id="amount"
                                       class="bg-transparent border-0 text-white fw-bold"
                                       readonly />
                            </div>
                        </div>

                        <div>
                            <span class="badge bg-light text-dark px-3 py-2">Otomatik Hesap</span>
                        </div>

                    </div>

                    <!-- DATE -->
                    <div class="mt-4">
                        <label class="form-label fw-semibold">Tarih</label>
                        <input asp-for="Date"
                               class="form-control form-control-lg rounded-3"
                               type="datetime-local"
                               value="@Model.Date.ToString("yyyy-MM-ddTHH:mm")" />
                    </div>

                    <!-- INFO -->
                    <p class="text-muted small mt-3">
                        Kayıt Purchase tablosuna yazılır ve Stock tablosuna <strong>pozitif</strong> giriş yapılır.
                    </p>

                    <!-- ACTIONS -->
                    <div class="d-flex justify-content-center gap-3 mt-4">

                        <button type="submit" class="btn btn-primary btn-lg px-5 rounded-3">
                            Kaydet
                        </button>

                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5 rounded-3">
                            İptal
                        </a>

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>
@section Scripts {
    <script>
        function calcAmount() {
            const q = parseFloat(document.getElementById('quantity').value) || 0;
            const p = parseFloat(document.getElementById('price').value) || 0;

            document.getElementById('amount').value = (q * p).toFixed(2);
        }

        document.getElementById('quantity').addEventListener('input', calcAmount);
        document.getElementById('price').addEventListener('input', calcAmount);
    </script>
}